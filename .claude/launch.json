{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Firebase Emulator Suite",
      "runtimeExecutable": "firebase",
      "runtimeArgs": ["emulators:start", "--only", "firestore,auth,ui"],
      "port": 4001
    },
    {
      "name": "Jest Test Watcher",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test:watch"],
      "port": null
    }
  ]
}
